# ─────────────────────────────────────────────
# Fichier de configuration — COPIEZ en .env
# Ne jamais committer ce fichier avec vos vraies clés !
# ─────────────────────────────────────────────

# ── TELEGRAM ──────────────────────────────────
# Créez votre bot via @BotFather sur Telegram
# Commande : /newbot → choisir un nom → copier le token
TELEGRAM_TOKEN=7xxxxxxxxx:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Votre Chat ID personnel (envoyez /start à @userinfobot pour l'obtenir)
TELEGRAM_CHAT_ID=123456789

# ── BROKER ────────────────────────────────────
# Choisir : "demo" | "mt5" | "binance" | "oanda"
BROKER=demo

# ── MetaTrader 5 ──────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=VotreMotDePasse
MT5_SERVER=VotreBroker-Demo

# ── Binance ───────────────────────────────────
BINANCE_API_KEY=votre_api_key_binance
BINANCE_API_SECRET=votre_api_secret_binance

# ── OANDA ─────────────────────────────────────
OANDA_API_KEY=votre_cle_api_oanda
OANDA_ACCOUNT_ID=votre_account_id_oanda

# ── NEWS API ──────────────────────────────────
# Optionnel — ForexFactory est utilisé par défaut (sans clé)
NEWS_API_KEY=
